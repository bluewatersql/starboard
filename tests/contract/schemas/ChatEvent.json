{
  "$defs": {
    "EventType": {
      "description": "Event types for server-sent events (SSE).",
      "enum": [
        "thinking",
        "step.complete",
        "error",
        "tool_start",
        "tool.call.start",
        "tool.progress",
        "tool_end",
        "tool.call.result",
        "user_input_request",
        "user_input_response",
        "final_output",
        "next_steps",
        "clarification.request",
        "handoff",
        "routing.decision",
        "friendly_name.update",
        "agent.transition",
        "checkpoint",
        "interrupt.received",
        "replan",
        "solicitation",
        "message.start",
        "message.delta",
        "message.end",
        "step.start"
      ],
      "title": "EventType",
      "type": "string"
    }
  },
  "description": "A single Server-Sent Event in a conversation stream.\n\nArgs:\n    event_id: Unique event identifier (for resumption with Last-Event-ID).\n    type: Type of event (message.start, message.delta, etc.).\n    data: Event payload (varies by event type).\n    timestamp: UTC timestamp when event was emitted.\n\nExamples:\n    >>> event = ChatEvent(\n    ...     event_id=\"evt_001\",\n    ...     type=EventType.MESSAGE_DELTA,\n    ...     data={\"message_id\": \"msg_abc\", \"delta\": {\"content\": \"Hello\"}},\n    ...     timestamp=datetime.utcnow()\n    ... )",
  "properties": {
    "event_id": {
      "description": "Unique event identifier",
      "maxLength": 100,
      "minLength": 1,
      "title": "Event Id",
      "type": "string"
    },
    "type": {
      "$ref": "#/$defs/EventType",
      "description": "Type of event"
    },
    "data": {
      "additionalProperties": true,
      "description": "Event payload",
      "title": "Data",
      "type": "object"
    },
    "timestamp": {
      "description": "UTC timestamp when event was emitted",
      "format": "date-time",
      "title": "Timestamp",
      "type": "string"
    }
  },
  "required": [
    "event_id",
    "type",
    "data",
    "timestamp"
  ],
  "title": "ChatEvent",
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "starboard://ChatEvent"
}