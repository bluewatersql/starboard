{
  "$defs": {
    "MessageStatus": {
      "description": "Status of message processing.",
      "enum": [
        "pending",
        "processing",
        "completed",
        "failed"
      ],
      "title": "MessageStatus",
      "type": "string"
    }
  },
  "description": "Response after submitting a message.",
  "properties": {
    "message_id": {
      "title": "Message Id",
      "type": "string"
    },
    "conversation_id": {
      "title": "Conversation Id",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/MessageStatus"
    },
    "trace_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Trace Id"
    }
  },
  "required": [
    "message_id",
    "conversation_id",
    "status"
  ],
  "title": "MessageResponse",
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "starboard://MessageResponse"
}