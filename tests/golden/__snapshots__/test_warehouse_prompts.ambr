# name: TestWarehouseToolSchemaGolden.test_chargeback_schema_structure
  dict({
    'description': '''
      Generate cost chargeback report for a specific warehouse.
      Returns: User cost allocations based on usage share.
      Use for: Cost attribution, accountability reporting.
      Cost: ~400 tokens | Prerequisites: warehouse_id, total_cost_usd (get from portfolio)
      ⚡ Parallel-safe: Yes - can generate for multiple warehouses in ONE turn
      → IMPORTANT: Get total_cost_usd from get_warehouse_portfolio first!
    ''',
    'name': 'generate_warehouse_chargeback',
    'parameters': dict({
      'properties': dict({
        'allocation_method': dict({
          'default': 'runtime',
          'description': 'How to allocate costs',
          'enum': list([
            'runtime',
            'queries',
            'bytes',
          ]),
          'type': 'string',
        }),
        'total_cost_usd': dict({
          'description': 'Total cost to allocate across users',
          'type': 'number',
        }),
        'warehouse_id': dict({
          'description': 'The warehouse ID to generate chargeback for',
          'type': 'string',
        }),
        'window_days': dict({
          'default': 30,
          'description': 'Analysis window in days',
          'type': 'integer',
        }),
      }),
      'required': list([
        'warehouse_id',
        'total_cost_usd',
      ]),
      'type': 'object',
    }),
  })
# ---
# name: TestWarehouseToolSchemaGolden.test_fingerprint_schema_structure
  dict({
    'description': '''
      Generate detailed fingerprint for a specific warehouse including performance percentiles, workload patterns, time distribution, and query type breakdown.
      Returns: Detailed performance metrics, user breakdown, query patterns.
      Use for: Deep analysis of a single warehouse.
      Cost: ~800 tokens | Prerequisites: warehouse_id
      ⚡ Parallel-safe: Yes - can call for multiple warehouses in ONE turn
      → Next: get_warehouse_health (for SLO compliance), evaluate_warehouse_scenario (for optimization)
    ''',
    'name': 'get_warehouse_fingerprint',
    'parameters': dict({
      'properties': dict({
        'warehouse_id': dict({
          'description': 'The warehouse ID to analyze',
          'type': 'string',
        }),
        'window_days': dict({
          'default': 7,
          'description': 'Analysis window in days',
          'enum': list([
            7,
            30,
            90,
          ]),
          'type': 'integer',
        }),
      }),
      'required': list([
        'warehouse_id',
      ]),
      'type': 'object',
    }),
  })
# ---
# name: TestWarehouseToolSchemaGolden.test_health_schema_structure
  dict({
    'description': '''
      Get health score and SLO compliance for a warehouse.
      Returns: Overall score (0-100), risk factors, SLO compliance, recommendations.
      Use for: Assess a specific warehouse's health and get actionable suggestions.
      Cost: ~500 tokens | Prerequisites: warehouse_id
      ⚡ Parallel-safe: Yes - can call for multiple warehouses in ONE turn
      → Next: evaluate_warehouse_scenario (if issues found), configure_warehouse_slo (to set targets)
    ''',
    'name': 'get_warehouse_health',
    'parameters': dict({
      'properties': dict({
        'warehouse_id': dict({
          'description': 'The warehouse ID to analyze',
          'type': 'string',
        }),
        'window_days': dict({
          'default': 7,
          'description': 'Analysis window in days',
          'type': 'integer',
        }),
      }),
      'required': list([
        'warehouse_id',
      ]),
      'type': 'object',
    }),
  })
# ---
# name: TestWarehouseToolSchemaGolden.test_portfolio_schema_structure
  dict({
    'description': '''
      Get portfolio view of all SQL warehouses with health scores, performance metrics, and summary statistics.
      Returns: Warehouse list with health scores, cost, query counts, utilization.
      Use for: Fleet-wide visibility, identify warehouses needing attention.
      Cost: ~600 tokens | Prerequisites: None
      ⚡ Parallel-safe: Yes - can call with other tools in ONE turn
      → Next: get_warehouse_fingerprint (for deep dive), get_warehouse_health (for specific issues)
    ''',
    'name': 'get_warehouse_portfolio',
    'parameters': dict({
      'properties': dict({
        'include_inactive': dict({
          'default': False,
