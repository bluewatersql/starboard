# Starboard AI Agent - Environment Variables Example
# Copy to .env in project root and configure for your environment
#
# Configuration Hierarchy (highest to lowest precedence):
# 1. CLI Arguments (--model, --max-tokens, etc.)
# 2. Environment Variables (this file)
# 3. Config File (~/.starboard/config.yaml)
# 4. Code Defaults (built-in values)

# ============================================================================
# Databricks Configuration
# ============================================================================
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi...

# SQL Warehouse ID (optional)
# If not set, the workspace's default warehouse will be used automatically.
# Get from: Databricks Workspace > SQL Warehouses > [warehouse] > Connection Details
# DATABRICKS_WAREHOUSE_ID=abc123...

# Default catalog and schema for queries
DEFAULT_CATALOG=main
DEFAULT_SCHEMA=default

# ============================================================================
# LLM Configuration
# ============================================================================
# LLM Provider (openai, anthropic, databricks)
LLM_PROVIDER=openai

# API Key (required)
LLM_API_KEY=sk-...
# Or use OPENAI_API_KEY for backward compatibility
OPENAI_API_KEY=sk-...

# Model selection
LLM_MODEL=databricks-claude-sonnet-4-5
# Options: databricks-claude-sonnet-4-5, gpt-4o, gpt-4o-mini, o1-preview

# Base URL (optional, for custom endpoints)
LLM_BASE_URL=

# Temperature (0.0 = deterministic, 2.0 = creative)
LLM_TEMPERATURE=0.4

# Max tokens per request
LLM_MAX_TOKENS=75000

# Random seed for reproducibility (optional)
LLM_SEED=

# Embedding model (must match your serving endpoint)
# For Databricks Foundation Model API: databricks-gte-large-en, databricks-bge-large-en
# For OpenAI: text-embedding-3-small, text-embedding-ada-002
EMBEDDING_MODEL=databricks-bge-large-en

# Embedding base URL (optional, uses LLM_BASE_URL when empty)
# Set to decouple embedding provider from chat provider.
# Example: EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_BASE_URL=

# ============================================================================
# Specialized LLM Models (Optional Overrides)
# ============================================================================
# Planning model (for complex reasoning tasks)
LLM_PLANNING_MODEL=gpt-4o
LLM_PLANNING_TEMPERATURE=0.3

# Judge model (for evaluation and scoring)
LLM_JUDGE_MODEL=gpt-4o
LLM_JUDGE_TEMPERATURE=0.2

# Review model (for code/query review)
LLM_REVIEW_MODEL=gpt-4o
LLM_REVIEW_TEMPERATURE=0.3

# Synthesis model (for summarization)
LLM_SYNTH_MODEL=gpt-4o
LLM_SYNTH_TEMPERATURE=0.4

# ============================================================================
# Multi-Agent Configuration (Phase 3 & 4)
# ============================================================================
# Enable multi-agent routing (default: false for backward compatibility)
ENABLE_MULTI_AGENT_ROUTING=false

# Percentage of conversations to route to multi-agent (0.0-1.0)
# Use for gradual rollout: 0.0 → 0.05 → 0.25 → 0.50 → 1.0
MULTI_AGENT_ROLLOUT_PERCENTAGE=0.0

# Comma-separated list of domains to disable from routing
# Available domains: query, job, uc, cluster, diagnostic, analytics, warehouse, discovery
# Example: DISABLED_AGENT_DOMAINS=diagnostic,discovery
DISABLED_AGENT_DOMAINS=

# Per-domain model overrides (JSON format)
# Example: {"router": "gpt-4o-mini", "query": "gpt-4o", "diagnostic": "o1-preview"}
DOMAIN_MODEL_OVERRIDES=

# Per-domain temperature overrides (JSON format)
# Example: {"router": 0.2, "query": 0.3, "diagnostic": 0.7}
DOMAIN_TEMPERATURE_OVERRIDES=

# ============================================================================
# Query Map v2 Template System (Feature Flag - Phase 1)
# ============================================================================

# Enable v2 query templates (default: false for backward compatibility)
ENABLE_QUERY_TEMPLATES=false

# Percentage of requests to route to v2 templates (0-100)
# Use for gradual rollout: 0 → 10 → 25 → 50 → 100
QUERY_TEMPLATES_ROLLOUT_PCT=0

# Minimum confidence threshold for template matching (0.0-1.0)
# Lower = more matches, higher = higher precision
QUERY_TEMPLATES_MIN_CONFIDENCE=0.65

# LLM client for template matching (required if v2 enabled)
# Use existing OPENAI_API_KEY or ANTHROPIC_API_KEY

# ============================================================================
# Agent Configuration
# ============================================================================
# Maximum parallel tool calls
TOOL_PARALLELISM=4

# ============================================================================
# Analytics Configuration
# ============================================================================
# Maximum rows to return from analytics queries
MAX_ANALYSIS_RESULT_ROWS=50

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=false

# ============================================================================
# Optional Features
# ============================================================================
# Redis URL for distributed caching
REDIS_URL=

# Safe mode (disable destructive operations)
SAFE_MODE=false

# Offline mode (no external API calls)
OFFLINE_MODE=false

# Mock LLM (for testing)
MOCK_LLM=false

# Enable streaming responses
ENABLE_STREAMING=true

# Enable result caching
ENABLE_CACHING=true

# Enable PII redaction in logs and MCP output (off by default)
ENABLE_PII_REDACTION=false

# ============================================================================
# State Management Configuration
# ============================================================================
# Environment (dev, test, staging, production)
ENVIRONMENT=dev

# Database backend (sqlite, postgres, databricks)
DATABASE_BACKEND=sqlite

# SQLite database paths (sqlite backend only)
SQLITE_STATE_PATH=./dev_data/starboard_state.db
SQLITE_MEMORY_PATH=./dev_data/starboard_memory.db

# PostgreSQL connection string (postgres backend only)
DATABASE_URL=postgresql://user:pass@host:5432/db

# Databricks Lakebase configuration (databricks backend only)
LAKEBASE_INSTANCE_NAME=my-lakebase
LAKEBASE_DATABASE_NAME=starboard_db

# Cache TTL (seconds)
CACHE_TTL=300

# PostgreSQL connection pool settings
POSTGRES_MIN_POOL_SIZE=5
POSTGRES_MAX_POOL_SIZE=20
POSTGRES_COMMAND_TIMEOUT=60

# Memory consolidation
MEMORY_CONSOLIDATION_ENABLED=false
MEMORY_CONSOLIDATION_INTERVAL=3600

# Embedding cache TTL (seconds)
EMBEDDING_CACHE_TTL=86400

# ============================================================================
# Quick Start Examples
# ============================================================================

# Development (v1 mode, no persistence):
#   ENABLE_QUERY_TEMPLATES=false
#   ENVIRONMENT=dev
#   make dev-server

# Development (v2 mode enabled):
#   ENABLE_QUERY_TEMPLATES=true
#   QUERY_TEMPLATES_ROLLOUT_PCT=100
#   OPENAI_API_KEY=sk-...
#   make dev-server

# Gradual rollout (10% of requests to v2):
#   ENABLE_QUERY_TEMPLATES=true
#   QUERY_TEMPLATES_ROLLOUT_PCT=10
#   make dev-server

# Multi-agent with v2 templates:
#   ENABLE_MULTI_AGENT_ROUTING=true
#   MULTI_AGENT_ROLLOUT_PERCENTAGE=0.5
#   ENABLE_QUERY_TEMPLATES=true
#   QUERY_TEMPLATES_ROLLOUT_PCT=50
#   make dev-server

