{
  "default_workspace_id": "production",
  "workspaces": {
    "production": {
      "host": "https://YOUR_PRODUCTION_WORKSPACE.cloud.databricks.com",
      "token_env": "DATABRICKS_TOKEN_PROD",
      "warehouse_id": "YOUR_WAREHOUSE_ID",
      "default_catalog": "main",
      "default_schema": "default"
    },
    "staging": {
      "host": "https://YOUR_STAGING_WORKSPACE.cloud.databricks.com",
      "token_env": "DATABRICKS_TOKEN_STAGING"
    }
  },
  "tool_scope": "phase_b",
  "rate_limit_per_minute": 60,
  "max_response_size_bytes": 65536,
  "agent_timeout": 900,
  "safe_mode": false
}
