{
  "_comment": "Copy to ~/Library/Application Support/Claude/claude_desktop_config.json (macOS) or %APPDATA%/Claude/claude_desktop_config.json (Windows)",
  "mcpServers": {
    "starboard": {
      "command": "starboard-mcp",
      "args": ["--transport", "stdio"],
      "env": {
        "DATABRICKS_HOST": "https://YOUR_WORKSPACE.cloud.databricks.com",
        "DATABRICKS_TOKEN": "dapi_YOUR_TOKEN_HERE",
        "LLM_PROVIDER": "openai",
        "LLM_API_KEY": "sk-YOUR_KEY_HERE",
        "LLM_MODEL": "gpt-4o"
      }
    }
  }
}
