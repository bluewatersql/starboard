# =============================================================================
# Starboard AI Agent — Environment Configuration
# =============================================================================
# Copy this file to .env in the project root and fill in your values.
# Generated from EnvConfig (packages/starboard-server/starboard_server/infra/core/config.py)
#
# Required fields are marked with [REQUIRED].
# Optional fields show their default values.

# -----------------------------------------------------------------------------
# Databricks Configuration
# -----------------------------------------------------------------------------

# [REQUIRED] Your Databricks workspace URL (e.g., https://adb-1234567890.12.azuredatabricks.net)
DATABRICKS_HOST=

# [REQUIRED] Databricks personal access token or OAuth token
DATABRICKS_TOKEN=

# Databricks SQL Warehouse ID for query execution
DATABRICKS_WAREHOUSE_ID=

# Default Unity Catalog and schema for queries
DEFAULT_CATALOG=main
DEFAULT_SCHEMA=default

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------

# LLM provider (openai, azure, databricks)
LLM_PROVIDER=openai

# [REQUIRED] API key for LLM provider (falls back to OPENAI_API_KEY)
LLM_API_KEY=

# Model identifier
LLM_MODEL=databricks-claude-sonnet-4-5

# Base URL for LLM API (leave empty for default)
LLM_BASE_URL=

# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.4

# Maximum tokens per LLM response
LLM_MAX_TOKENS=75000

# Random seed for reproducible LLM responses (optional)
# LLM_SEED=

# Embedding model for vector search
EMBEDDING_MODEL=databricks-bge-large-en

# Base URL for embedding API (leave empty for default)
EMBEDDING_BASE_URL=

# Embedding cache TTL in seconds (default: 24 hours)
EMBEDDING_CACHE_TTL=86400

# -----------------------------------------------------------------------------
# Specialized LLM Models (Per-Operation Overrides)
# -----------------------------------------------------------------------------
# These override the default LLM_MODEL for specific operations.
# Leave unset to use the default model.

# LLM_PLANNING_MODEL=
# LLM_PLANNING_TEMPERATURE=
# LLM_JUDGE_MODEL=
# LLM_JUDGE_TEMPERATURE=
# LLM_REVIEW_MODEL=
# LLM_REVIEW_TEMPERATURE=
# LLM_SYNTH_MODEL=
# LLM_SYNTH_TEMPERATURE=

# -----------------------------------------------------------------------------
# Multi-Agent Configuration
# -----------------------------------------------------------------------------

# Comma-separated list of agent domains to disable from routing
# Example: diagnostic,table,compute
# DISABLED_AGENT_DOMAINS=

# Per-domain model overrides (JSON)
# Example: {"router": "gpt-4o-mini", "query": "gpt-4o"}
# DOMAIN_MODEL_OVERRIDES=

# Per-domain temperature overrides (JSON)
# Example: {"router": 0.2, "query": 0.3}
# DOMAIN_TEMPERATURE_OVERRIDES=

# Maximum parallel tool calls per agent step
TOOL_PARALLELISM=4

# Maximum rows returned from analytics queries
MAX_ANALYSIS_RESULT_ROWS=50

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Bind address and port
HOST=0.0.0.0
PORT=8000

# Debug mode (enables verbose logging)
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# JSON-formatted log output (for production log aggregation)
LOG_JSON=false

# Environment: dev, test, staging, production
ENVIRONMENT=dev

# -----------------------------------------------------------------------------
# Database Backend (State Management)
# -----------------------------------------------------------------------------

# Backend type: sqlite (dev), postgres (prod), databricks
DATABASE_BACKEND=sqlite

# Connection string for postgres/databricks backends
# Example: postgresql://user:pass@localhost:5432/starboard
# DATABASE_URL=

# SQLite file paths (used when DATABASE_BACKEND=sqlite)
SQLITE_STATE_PATH=./dev_data/starboard_state.db
SQLITE_MEMORY_PATH=./dev_data/starboard_memory.db
SQLITE_VECTOR_PATH=./dev_data/starboard_vectors.db
SQLITE_REFLEXION_PATH=./dev_data/starboard_reflexion.db

# Postgres connection pool settings
POSTGRES_MIN_POOL_SIZE=5
POSTGRES_MAX_POOL_SIZE=20
POSTGRES_COMMAND_TIMEOUT=60

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------

# Cache backend: memory (dev), redis (prod), postgres
CACHE_BACKEND=memory

# Cache TTL in seconds
CACHE_TTL=300

# Redis URL (required when CACHE_BACKEND=redis)
# REDIS_URL=

# -----------------------------------------------------------------------------
# Vector Store Configuration
# -----------------------------------------------------------------------------

# Vector backend: sqlite (dev), chroma, databricks, postgres
VECTOR_BACKEND=sqlite

# Embedding vector dimension
EMBEDDING_DIMENSION=1024

# LLM model for vector metadata enrichment
VECTOR_METADATA_LLM_MODEL=databricks-gpt-5-mini
VECTOR_METADATA_LLM_TEMPERATURE=1.0
VECTOR_METADATA_LLM_MAX_TOKENS=5000

# Minimum similarity threshold for semantic cache hits (0.0-1.0)
SEMANTIC_CACHE_THRESHOLD=0.95

# -----------------------------------------------------------------------------
# Memory Consolidation
# -----------------------------------------------------------------------------

# Enable automatic memory consolidation
MEMORY_CONSOLIDATION_ENABLED=false

# Consolidation interval in seconds (default: 1 hour)
MEMORY_CONSOLIDATION_INTERVAL=3600

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Rate limit storage backend (memory:// or redis://...)
RATE_LIMIT_STORAGE=memory://

# Default rate limit for unprotected routes
RATE_LIMIT_DEFAULT=100/minute

# Maximum request body size in bytes (default: 10MB)
MAX_REQUEST_SIZE=10485760

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Disable all external API calls (for testing)
SAFE_MODE=false

# Disable external calls, use mock data
OFFLINE_MODE=false

# Use mock LLM responses (for testing)
MOCK_LLM=false

# Enable response caching
ENABLE_CACHING=true

# Enable OpenTelemetry observability
ENABLE_OBSERVABILITY=true

# Enable PII redaction in logs and responses
ENABLE_PII_REDACTION=false

# Enable reflexion (self-improvement) system
ENABLE_REFLEXION=false

# Enable semantic cache for LLM responses
ENABLE_SEMANTIC_CACHE=true

# -----------------------------------------------------------------------------
# Discovery Configuration
# -----------------------------------------------------------------------------

# Lookback period for discovery analysis (30, 60, or 90 days)
DISCOVERY_LOOKBACK_DAYS=30

# Maximum parallel discovery workers
DISCOVERY_MAX_PARALLELISM=4

# Comma-separated domains to analyze (empty = auto-detect)
# Example: billing,jobs,compute,query_performance
# DISCOVERY_DOMAINS=

# Skip LLM analysis and only collect raw query data
DISCOVERY_DATA_ONLY=false

# Output directory for discovery results
DISCOVERY_OUTPUT_DIR=./discovery_output

# Override LLM model for discovery analysis (falls back to LLM_MODEL)
# DISCOVERY_LLM_MODEL=

# Temperature for discovery LLM calls
DISCOVERY_LLM_TEMPERATURE=0.3
