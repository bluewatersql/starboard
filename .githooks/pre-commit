#!/bin/bash
#
# Pre-commit hook to auto-regenerate TypeScript types when Pydantic models change
#
# Installation:
#   .githooks/install.sh
#
# Or manually:
#   git config core.hooksPath .githooks

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get the list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Check if Pydantic model files were modified
MODELS_CHANGED=false
for file in $STAGED_FILES; do
  if [[ "$file" == "packages/starboard-server/starboard_server/api/v2/models.py" ]] || \
     [[ "$file" == "packages/starboard-server/starboard_server/api/v2/streaming_events.py" ]] || \
     [[ "$file" == "scripts/generate_types.py" ]]; then
    MODELS_CHANGED=true
    break
  fi
done

# If models changed, regenerate types
if [ "$MODELS_CHANGED" = true ]; then
  echo -e "${YELLOW}[pre-commit]${NC} Pydantic models changed, regenerating TypeScript types..."
  
  # Check if Python is available
  if ! command -v python3 &> /dev/null; then
    echo -e "${RED}[pre-commit]${NC} Python3 not found. Cannot regenerate types."
    echo -e "${YELLOW}[pre-commit]${NC} Please install Python3 or run manually:"
    echo -e "  python scripts/generate_types.py"
    exit 1
  fi
  
  # Check if virtual environment is activated
  if [ -z "$VIRTUAL_ENV" ]; then
    echo -e "${YELLOW}[pre-commit]${NC} Virtual environment not activated. Attempting to activate..."
    if [ -f ".venv/bin/activate" ]; then
      source .venv/bin/activate
    elif [ -f "venv/bin/activate" ]; then
      source venv/bin/activate
    else
      echo -e "${RED}[pre-commit]${NC} Virtual environment not found."
      echo -e "${YELLOW}[pre-commit]${NC} Please activate your venv or run manually:"
      echo -e "  python scripts/generate_types.py"
      exit 1
    fi
  fi
  
  # Run type generation
  if python scripts/generate_types.py; then
    # Check if types were actually changed
    if git diff --exit-code frontend/lib/types/generated-api.ts frontend/lib/validation/generated-schemas.ts > /dev/null 2>&1; then
      echo -e "${GREEN}[pre-commit]${NC} Types are already up to date."
    else
      echo -e "${GREEN}[pre-commit]${NC} Types regenerated successfully."
      echo -e "${YELLOW}[pre-commit]${NC} Staging updated type files..."
      
      # Stage the regenerated files
      git add frontend/lib/types/generated-api.ts
      git add frontend/lib/validation/generated-schemas.ts
      
      echo -e "${GREEN}[pre-commit]${NC} Updated types have been staged for commit."
    fi
  else
    echo -e "${RED}[pre-commit]${NC} Failed to regenerate types!"
    echo -e "${YELLOW}[pre-commit]${NC} Please fix the errors and try again."
    exit 1
  fi
fi

# All checks passed
echo -e "${GREEN}[pre-commit]${NC} All checks passed."
exit 0

