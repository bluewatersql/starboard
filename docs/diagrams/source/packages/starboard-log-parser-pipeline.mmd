    style StageParser fill:#06b6d4,color:#fff
    style TaskParser fill:#06b6d4,color:#fff
    style BuildApp fill:#10b981,color:#fff
    style ErrorLog fill:#ef4444,color:#fff
    style WarnLog fill:#f59e0b,color:#fff

