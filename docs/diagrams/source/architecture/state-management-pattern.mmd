%%{init: {'theme':'default', 'themeVariables': {'fontSize':'16px'}}}%%

graph TB
    subgraph "Application Layer"
        API[FastAPI Endpoints]
        Agents[Multi-Agent System]
    end
    
    subgraph "Repository Pattern - Abstraction"
        ConvRepo[ConversationRepository<br/>Protocol]
        EpisodeRepo[EpisodeRepository<br/>Protocol]
        FactRepo[FactRepository<br/>Protocol]
        UserRepo[UserRepository<br/>Protocol]
    end
    
    subgraph "Data Models"
        Conversation[Conversation<br/>id, user_id, created_at]
        Episode[Episode<br/>conversation_id, summary]
        Fact[Fact<br/>content, confidence, source]
        UserProfile[UserProfile<br/>id, preferences]
    end
    
    %% Application uses repositories
    API -->|Uses| ConvRepo
    API -->|Uses| UserRepo
    Agents -->|Uses| ConvRepo
    Agents -->|Uses| EpisodeRepo
    Agents -->|Uses| FactRepo
    
    %% Repositories return domain models
    ConvRepo -.->|Returns| Conversation
    EpisodeRepo -.->|Returns| Episode
    FactRepo -.->|Returns| Fact
    UserRepo -.->|Returns| UserProfile
    
    %% Note: Implementations injected at runtime
    Note1[Note: Storage implementations<br/>are injected via dependency injection]
    
