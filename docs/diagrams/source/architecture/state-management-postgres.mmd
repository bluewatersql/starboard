%%{init: {'theme':'default', 'themeVariables': {'fontSize':'16px'}}}%%

graph TB
    subgraph "Application Layer"
        API[FastAPI Endpoints]
        Agents[Multi-Agent System]
    end
    
    subgraph "Repository Protocols"
        ConvRepo[ConversationRepository]
        EpisodeRepo[EpisodeRepository]
        FactRepo[FactRepository]
        UserRepo[UserRepository]
    end
    
    subgraph "PostgreSQL Implementation"
        PGConv[PostgresConversationStore<br/>asyncpg + pgvector]
        PGEp[PostgresEpisodeStore]
        PGFact[PostgresFactStore]
        PGUser[PostgresUserStore]
    end
    
    subgraph "PostgreSQL Database"
        PGDB[(PostgreSQL Database<br/>pgvector extension<br/>Connection pooling)]
    end
    
    subgraph "Data Models"
        Conversation[Conversation]
        Episode[Episode]
        Fact[Fact]
        UserProfile[UserProfile]
    end
    
    %% Application uses repositories
    API -->|Uses| ConvRepo
    API -->|Uses| UserRepo
    Agents -->|Uses| ConvRepo
    Agents -->|Uses| EpisodeRepo
    Agents -->|Uses| FactRepo
    
    %% Protocols implemented by Postgres
    ConvRepo -.->|Implemented by| PGConv
    EpisodeRepo -.->|Implemented by| PGEp
    FactRepo -.->|Implemented by| PGFact
    UserRepo -.->|Implemented by| PGUser
    
    %% Postgres stores to database
    PGConv -->|Stores| PGDB
    PGEp -->|Stores| PGDB
    PGFact -->|Stores| PGDB
    PGUser -->|Stores| PGDB
    
    %% Returns domain models
    PGConv -->|Returns| Conversation
    PGEp -->|Returns| Episode
    PGFact -->|Returns| Fact
    PGUser -->|Returns| UserProfile
    
    Note1[Use Case: Production Deployment<br/>Features: pgvector for vector similarity<br/>Connection pooling for performance<br/>ACID transactions, scalability]
    
    style API fill:#4f46e5,color:#fff
    style Agents fill:#06b6d4,color:#fff
    style ConvRepo fill:#8b5cf6,color:#fff
    style EpisodeRepo fill:#8b5cf6,color:#fff
    style FactRepo fill:#8b5cf6,color:#fff
    style UserRepo fill:#8b5cf6,color:#fff
