%%{init: {'theme':'default', 'themeVariables': {'fontSize':'16px'}}}%%

graph TB
    subgraph "Application Layer"
        API[FastAPI Endpoints]
        Agents[Multi-Agent System]
    end
    
    subgraph "Repository Protocols"
        ConvRepo[ConversationRepository]
        EpisodeRepo[EpisodeRepository]
        FactRepo[FactRepository]
        UserRepo[UserRepository]
    end
    
    subgraph "SQLite Implementation"
        SQLiteConv[SQLiteConversationStore<br/>aiosqlite + sqlite-vec]
        SQLiteEp[SQLiteEpisodeStore]
        SQLiteFact[SQLiteFactStore]
        SQLiteUser[SQLiteUserStore]
    end
    
    subgraph "SQLite Database"
        DB[(starboard_state.db<br/>Conversations, Episodes, Facts)]
    end
    
    subgraph "Data Models"
        Conversation[Conversation]
        Episode[Episode]
        Fact[Fact]
        UserProfile[UserProfile]
    end
    
    %% Application uses repositories
    API -->|Uses| ConvRepo
    API -->|Uses| UserRepo
    Agents -->|Uses| ConvRepo
    Agents -->|Uses| EpisodeRepo
    Agents -->|Uses| FactRepo
    
    %% Protocols implemented by SQLite
    ConvRepo -.->|Implemented by| SQLiteConv
    EpisodeRepo -.->|Implemented by| SQLiteEp
    FactRepo -.->|Implemented by| SQLiteFact
    UserRepo -.->|Implemented by| SQLiteUser
    
    %% SQLite stores to database
    SQLiteConv -->|Stores| DB
    SQLiteEp -->|Stores| DB
    SQLiteFact -->|Stores| DB
    SQLiteUser -->|Stores| DB
    
    %% Returns domain models
    SQLiteConv -->|Returns| Conversation
    SQLiteEp -->|Returns| Episode
    SQLiteFact -->|Returns| Fact
    SQLiteUser -->|Returns| UserProfile
    
    Note1[Use Case: Development and Testing<br/>Features: Vector search via sqlite-vec<br/>Location: dev_data/starboard_state.db]
    
