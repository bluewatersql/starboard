%%{init: {'theme':'default', 'themeVariables': {'fontSize':'16px'}}}%%

graph LR
    subgraph "Frontend"
        UI[Next.js UI]
    end
    
    subgraph "starboard-server"
        API[FastAPI API]
        Agents[Multi-Agent System]
        Tools[Tool System]
    end
    
    subgraph "starboard-core"
        Models[Domain Models<br/>Message, Conversation, Episode]
    end
    
    subgraph "starboard-log-parser"
        Parser[Log Parser<br/>Spark Event Logs]
    end
    
    subgraph "External"
        DB[Databricks API]
    end
    
    %% Frontend to server
    UI -->|HTTP/SSE| API
    
    %% Server internal
    API --> Agents
    Agents --> Tools
    
    %% Server uses core
    Agents -->|Uses| Models
    API -->|Uses| Models
    
    %% Tools use log parser
    Tools -->|Parses logs| Parser
    
    %% External calls
    Tools -->|API Calls| DB
    Parser -->|Reads logs| DB
    
    style UI fill:#06b6d4,color:#fff
    style API fill:#4f46e5,color:#fff
    style Agents fill:#7c3aed,color:#fff
    style Tools fill:#f59e0b,color:#fff
    style Models fill:#22c55e,color:#fff
    style Parser fill:#22c55e,color:#fff
    style DB fill:#ff6b6b,color:#fff

